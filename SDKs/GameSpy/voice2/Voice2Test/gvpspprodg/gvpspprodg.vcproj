	<Configurations>
		<Configuration
			Name="PSP Debug|Win32"
			OutputDirectory="PSP_Debug"
			IntermediateDirectory="PSP_Debug"
			ConfigurationType="1"
			DeleteExtensionsOnClean="*.obj;*.d;*.map;*.lst;*.pch;*.prx;$(TargetPath)">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="-g -O0 -Xdiag=2"
				AdditionalIncludeDirectories="&quot;C:\gamespy\GOA\Voice2\gsm-1.0-pl11\inc&quot;;&quot;$(SCE_PSP_HW_ROOT)include&quot;"
				PreprocessorDefinitions="SN_TARGET_PSP_PRX;_DEBUG;_PSP;UNIQUEID;GSI_COMMON_DEBUG;GV_CUSTOM_SOURCE_TYPE=SOCKADDR_IN;LTP_CUT"
				ProgramDataBaseFileName=""
				WarningLevel="4"
				WarnAsError="FALSE"
				CompileAs="0"
				ForcedIncludeFiles=""/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="-g"
				AdditionalDependencies="crt0_prx.o pspnet_stub_weak.a pspnet_inet_stub_weak.a pspnet_apctl_stub_weak.a; pspnet_ap_dialog_dummy_stub_weak.a rtc_stub.a utility_stub.a wlan_stub.a pspnet_resolver_stub_weak.a libwave.a audio_stub_02.a"
				OutputFile="$(OutDir)/tempprx.obj"
				AdditionalLibraryDirectories=""
				IgnoreAllDefaultLibraries="FALSE"
				ProgramDatabaseFile=""
				ImportLibrary=""/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"
				Description="Generating Debug PRX &quot;$(TargetDir)$(ProjectName).prx&quot;"
				CommandLine="pspprxgen &quot;$(TargetPath)&quot; -r &quot;$(TargetDir)$(ProjectName).prx&quot;"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
