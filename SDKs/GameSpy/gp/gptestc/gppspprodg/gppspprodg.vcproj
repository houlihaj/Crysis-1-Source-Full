<?xml version="1.0" encoding="Windows-1252"?>
<VisualStudioProject
	ProjectType="Visual C++"
	Version="7.10"
	Name="gppspprodg"
	ProjectGUID="{E95E1EE9-B275-43C2-A90F-11B505A22EA0}"
	RootNamespace="gppspprodg"
	SccProjectName="$/Gamespy/GOA/GP/gptestc/gppspprodg"
	SccAuxPath=""
	SccLocalPath="."
	SccProvider="MSSCCI:SourceGear Vault Client">
	<Platforms>
		<Platform
			Name="Win32"/>
	</Platforms>
	<Configurations>
		<Configuration
			Name="PSP Debug|Win32"
			OutputDirectory="PSP_Debug"
			IntermediateDirectory="PSP_Debug"
			ConfigurationType="1"
			DeleteExtensionsOnClean="*.obj;*.d;*.map;*.lst;*.pch;$(TargetPath)">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="-g -O0 -G0"
				AdditionalIncludeDirectories=""
				PreprocessorDefinitions="SN_TARGET_PSP_PRX;_DEBUG;_PSP"
				ProgramDataBaseFileName=""
				WarningLevel="4"
				WarnAsError="FALSE"
				CompileAs="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="-G0 -g"
				AdditionalDependencies="crt0_prx.o pspnet_stub_weak.a pspnet_inet_stub_weak.a pspnet_apctl_stub_weak.a pspnet_ap_dialog_dummy_stub_weak.a  wlan_stub.a rtc_stub.a pspnet_resolver_stub_weak.a utility_stub.a "
				OutputFile="$(OutDir)/tempprx.obj"
				AdditionalLibraryDirectories=""
				ProgramDatabaseFile=""/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"
				Description="Generating Debug PRX &quot;$(TargetDir)$(ProjectName).prx&quot;"
				CommandLine="pspprxgen &quot;$(TargetPath)&quot; -r &quot;$(TargetDir)$(ProjectName).prx&quot;"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
		<Configuration
			Name="PSP Release|Win32"
			OutputDirectory="PSP_Release"
			IntermediateDirectory="PSP_Release"
			ConfigurationType="1"
			DeleteExtensionsOnClean="*.obj;*.d;*.map;*.lst;*.pch;$(TargetPath)">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="-O3 -G0"
				AdditionalIncludeDirectories=""
				PreprocessorDefinitions="SN_TARGET_PSP_PRX;NDEBUG;_PSP"
				ProgramDataBaseFileName=""
				WarningLevel="4"
				WarnAsError="TRUE"
				CompileAs="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="-G0 -Wl,-S -Wl,-Map,&quot;$(OutDir)/$(ProjectName).map&quot; -Wl,-sn-full-map"
				AdditionalDependencies="crt0_prx.o pspnet_stub_weak.a pspnet_inet_stub_weak.a pspnet_apctl_stub_weak.a pspnet_ap_dialog_dummy_stub_weak.a  wlan_stub.a rtc_stub.a pspnet_resolver_stub_weak.a utility_stub.a "
				OutputFile="$(OutDir)/tempprx.obj"
				AdditionalLibraryDirectories=""
				ProgramDatabaseFile=""/>
			<Tool
				Name="VCMIDLTool"/>
			<Tool
				Name="VCPostBuildEventTool"
				Description="Generating Release PRX &quot;$(TargetDir)$(ProjectName).prx&quot;"
				CommandLine="pspprxgen &quot;$(TargetPath)&quot; -o &quot;$(TargetDir)$(ProjectName).prx&quot;"/>
			<Tool
				Name="VCPreBuildEventTool"/>
			<Tool
				Name="VCPreLinkEventTool"/>
			<Tool
				Name="VCResourceCompilerTool"/>
			<Tool
				Name="VCWebServiceProxyGeneratorTool"/>
			<Tool
				Name="VCXMLDataGeneratorTool"/>
			<Tool
				Name="VCWebDeploymentTool"/>
			<Tool
				Name="VCManagedWrapperGeneratorTool"/>
			<Tool
				Name="VCAuxiliaryManagedWrapperGeneratorTool"/>
		</Configuration>
