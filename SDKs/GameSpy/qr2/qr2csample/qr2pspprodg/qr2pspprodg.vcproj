				Name="VCCLCompilerTool"
				AdditionalOptions="-g -O3"
				AdditionalIncludeDirectories="$(SCE_PSP_HW_ROOT)include"
				PreprocessorDefinitions="SN_TARGET_PSP_PRX;_DEBUG;_PSP;UNIQUEID;GSI_COMMON_DEBUG"
				ProgramDataBaseFileName=""
				WarningLevel="4"
				CompileAs="0"/>
			<Tool
				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				AdditionalOptions="-g"
