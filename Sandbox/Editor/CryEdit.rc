    ID_TANGENT_IN_AUTO      "Set In Tangent to Auto\nSet In Tangent to Auto"
    ID_TANGENT_IN_STEP      "Set In Tangent to Step\nSet In Tangent to Step"
    ID_TANGENT_OUT_ZERO     "Set Out Tangent to Zero\nSet Out Tangent to Zero"
    ID_TANGENT_OUT_AUTO     "Set Out Tangent to Auto\nSet Out Tangent to Auto"
    ID_TANGENT_OUT_STEP     "Set Out Tangent to Auto\nSet Out Tangent to Auto"
    ID_TANGENT_AUTO         "Set In/Out Tangents to Auto\nSet In/Out Tangents to Auto"
    ID_TANGENT_IN_LINEAR    "Set In Tangent to Linear\nSet In Tangent to Linear"
    ID_TANGENT_OUT_LINEAR   "Set Out Tangent to Linear\nSet Out Tangent to Linear"
    ID_SPLINE_FIT_X         "Fit splines to the visible width\nFit splines to the visible width"
    ID_SPLINE_FIT_Y         "Fit splines to the visible height\nFit splines to the visible height"
    ID_SPLINE_SNAP_GRID_X   "Snap to time grid\nSnap to time grid"
    ID_SPLINE_SNAP_GRID_Y   "Snap to value grid\nSnap to value grid"
END

