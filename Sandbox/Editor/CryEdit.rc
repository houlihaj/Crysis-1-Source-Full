IDD_CHARACTER_EDITOR_ANIMATIONCONTROL DIALOGEX 0, 0, 623, 108
STYLE DS_SETFONT | WS_CHILD
FONT 8, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    GROUPBOX        "Animation Control",IDC_PROGRESSGROUPBOX,282,7,325,54
    LTEXT           "Progress:",IDC_STATIC,290,18,32,8
    EDITTEXT        IDC_PROGRESSEDIT,324,16,52,14,ES_AUTOHSCROLL
    CONTROL         "",IDC_PROGRESSSLIDER,"msctls_trackbar32",TBS_BOTH | TBS_NOTICKS | WS_TABSTOP,288,32,199,12
    PUSHBUTTON      "Button2",IDC_PLAYPAUSE,383,16,20,14,BS_ICON | BS_FLAT
    EDITTEXT        IDC_ANIMATION_NAME,345,46,224,12,ES_AUTOHSCROLL | ES_READONLY | NOT WS_BORDER
    LTEXT           "Animation Asset:",IDC_STATIC,290,46,55,8
    CONTROL         "",IDC_EVENT_LIST,"SysListView32",LVS_REPORT | LVS_SHOWSELALWAYS | LVS_EDITLABELS | LVS_ALIGNLEFT | LVS_OWNERDATA | WS_BORDER | WS_TABSTOP,7,16,259,85
    PUSHBUTTON      "New Event",IDC_ADD_EVENT,377,77,51,14
    PUSHBUTTON      "Delete Event",IDC_DELETE_EVENTS,432,77,51,14
    GROUPBOX        "Events",IDC_STATIC,7,7,267,94
    PUSHBUTTON      "Load",IDC_LOAD_ANIM_EVENTS,287,77,41,14
    PUSHBUTTON      "Save",IDC_SAVE_ANIM_EVENTS,332,77,41,14
    GROUPBOX        "Modify Events",IDC_STATIC,282,65,326,32
    PUSHBUTTON      "Select Sound",IDC_SELECT_SOUND,486,76,48,15
    PUSHBUTTON      "Use Selected Effect",IDC_USE_SELECTED_EFFECT,537,76,68,14
END

IDD_MATERIAL_SELECTOR DIALOGEX 0, 0, 188, 224
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Select Material"
FONT 8, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,130,203,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,77,203,50,14
    CONTROL         "",IDC_MATERIAL_BROWSER_PARENT,"Static",SS_BLACKFRAME,7,7,173,133
    EDITTEXT        IDC_MATERIAL_NAME,7,143,173,14,ES_AUTOHSCROLL
    CONTROL         "",IDC_MATERIAL_IMAGE_PARENT,"Static",SS_BLACKFRAME,7,160,173,41
END

