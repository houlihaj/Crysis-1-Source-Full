//

IDR_FACED_MENU MENU 
BEGIN
    POPUP "Project"
    BEGIN
        MENUITEM "&New",                        ID_PROJECT_NEW
        MENUITEM "&Open",                       ID_PROJECT_OPEN
        MENUITEM "&Save",                       ID_PROJECT_SAVE
        MENUITEM "Save &As",                    ID_PROJECT_SAVEAS
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo",                       ID_UNDO
        MENUITEM "&Redo",                       ID_REDO
    END
    POPUP "Expressions Library"
    BEGIN
        MENUITEM "&New",                        ID_EXP_LIBRARY_NEW
        MENUITEM "&Open",                       ID_EXP_LIBRARY_OPEN
        MENUITEM "&Save",                       ID_EXP_LIBRARY_SAVE
        MENUITEM "Save &As",                    ID_EXP_LIBRARY_SAVEAS
        MENUITEM SEPARATOR
        MENUITEM "E&xport Selected Expressions...", ID_EXP_LIBRARY_EXPORT
        MENUITEM "&Import Expressions...",      ID_EXP_LIBRARY_IMPORT
        MENUITEM "&Batch Update With Selected Expressions...", ID_EXP_LIBRARY_BATCHUPDATEEXPRESSIONLIBRARIES
        MENUITEM SEPARATOR
        MENUITEM "Morph &Check...",             ID_EXPRESSIONSLIBRARY_MORPHCHECK
    END
    POPUP "Character"
    BEGIN
        MENUITEM "Load",                        ID_CHARACTER_LOAD
    END
    POPUP "Sequence"
    BEGIN
        MENUITEM "&New",                        ID_SEQUENCE_NEW
        MENUITEM "&Open",                       ID_SEQUENCE_OPEN
        MENUITEM "&Save",                       ID_SEQUENCE_SAVE
        MENUITEM "Save &As",                    ID_SEQUENCE_SAVEAS
        MENUITEM SEPARATOR
        MENUITEM "Load Sound",                  ID_SEQUENCE_LOADSOUND
        MENUITEM "Load Skeleton Animation",     ID_SEQUENCE_LOADSKELETONANIMATION
        MENUITEM SEPARATOR
        MENUITEM "Batch Apply Expression...",   ID_SEQUENCE_BATCHAPPLYEXPRESSION
        MENUITEM SEPARATOR
        MENUITEM "E&xport Selected Expressions...", ID_SEQUENCE_EXPORTSELECTEDEXPRESSIONS
        MENUITEM "&Import Expressions...",      ID_SEQUENCE_IMPORTEXPRESSIONS
        MENUITEM "Batch &Update With Selected Expressions...", ID_SEQUENCE_BATCHUPDATESEQUENCES
        MENUITEM SEPARATOR
        MENUITEM "Load Video Extracted Sequence...", ID_SEQUENCE_LOADVIDEOEXTRACTEDSEQUENCE
        MENUITEM "Load and solve from a C3D file...", ID_SEQUENCE_LOADVIDEOIGNORESEQUENCE
        MENUITEM "Load Group File...",          ID_SEQUENCE_LOADGROUPFILE
    END
    POPUP "Joysticks"
    BEGIN
        MENUITEM "&New",                        ID_JOYSTICKS_NEW
        MENUITEM "&Open",                       ID_JOYSTICKS_OPEN
        MENUITEM "&Save",                       ID_JOYSTICKS_SAVE
        MENUITEM "Save &As",                    ID_JOYSTICKS_SAVEAS
        MENUITEM SEPARATOR
        MENUITEM "Create &Expression from Current Positions...", ID_JOYSTICKS_CREATEEXPRESSIONFROMCURRENTPOSITIONS
    END
    POPUP "Lip Sync"
    BEGIN
        MENUITEM "Extract Phonemes...",         ID_SEQUENCE_TEXT_LIPSYNC
        MENUITEM SEPARATOR
        MENUITEM "Batch Process Directory...",  ID_BATCHPROCESS_TEXTLESSEXTRACTIONOFDIRECTORY
    END
END

IDR_AIDEBUGGER_MENU MENU 
BEGIN
    POPUP "File"
    BEGIN
        MENUITEM "Load",                        ID_FILE_LOAD33869
        MENUITEM "Save",                        ID_FILE_SAVE33868
        MENUITEM "Load As",                     ID_FILE_LOADAS
        MENUITEM "Save As",                     ID_FILE_SAVEAS
    END
END


