IDD_VEED_MODS DIALOGEX 0, 0, 467, 207
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Vehicle Modifications"
FONT 8, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    LISTBOX         IDC_VEEDMOD_LIST,7,17,107,140,LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Add New",IDC_VEEDMOD_NEW,126,17,50,14
    PUSHBUTTON      "Clone",IDC_VEEDMOD_CLONE,126,37,50,14
    PUSHBUTTON      "Delete",IDC_VEEDMOD_DELETE,126,56,50,14
    PUSHBUTTON      "Cancel",IDC_VEEDMOD_CLOSE,64,184,50,14
    LTEXT           "Quick Edit",IDC_STATIC,190,7,32,8
    PUSHBUTTON      "Ok",IDC_VEEDMOD_SAVE,7,184,50,14
    LTEXT           "Modifications",IDC_STATIC,7,7,42,8
END

IDD_VEED_SCALE_HELPERS DIALOGEX 0, 0, 162, 87
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Update Vehicle Scale"
FONT 8, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,105,66,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,45,66,50,14
    LTEXT           "Note: This will affect all vehicle helpers, parts and components. Usually it's only needed if you want to adapt those to a rescaled model.",IDC_STATIC,7,28,148,36
    EDITTEXT        IDC_EDIT_SCALE,30,7,53,14,ES_AUTOHSCROLL,WS_EX_RIGHT
    LTEXT           "Scale",IDC_STATIC,7,10,18,8
END

IDD_CONFIRM_OVERWRITE DIALOGEX 0, 0, 221, 66
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Dialog"
FONT 8, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    EDITTEXT        IDC_MESSAGE,7,7,207,33,ES_MULTILINE | ES_AUTOHSCROLL | ES_READONLY | NOT WS_BORDER | NOT WS_TABSTOP
    DEFPUSHBUTTON   "&No",IDNO,7,45,50,14
    PUSHBUTTON      "&Yes",IDYES,59,45,50,14
    PUSHBUTTON      "No to A&ll",ID_NO_ALL,111,45,50,14
    PUSHBUTTON      "Yes to &All",ID_YES_ALL,164,45,50,14
END


